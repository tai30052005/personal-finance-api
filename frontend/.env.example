# Sao chép file này thành ".env" rồi điền giá trị thật.
# Vite chỉ nạp các biến bắt đầu bằng VITE_ vào code (qua import.meta.env).

# Địa chỉ backend API.
#  - Dev: http://localhost:8080
#  - Docker/production: để trống -> gọi "/api/..." qua Nginx proxy.
VITE_API_URL=http://localhost:8080

# ----- Cloudinary (đính ảnh hóa đơn vào giao dịch) -----
# Lấy ở Cloudinary Dashboard. Dùng "unsigned upload preset" để upload trực tiếp
# từ trình duyệt (không cần API secret). Bỏ trống -> tính năng đính ảnh tự ẩn.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
